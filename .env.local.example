# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# ---- Database ----
# MongoDB Atlas connection string (include the database name in the path).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wbstories

# ---- Auth ----
# Long random secret used to sign/verify admin session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# ---- Site ----
# Used for canonical URLs, sitemap.xml, robots.txt, and Open Graph metadata.
# In production this should be the public site's root domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- One-off admin seed script (scripts/seed-admin.ts) ----
# Only read by `npm run seed:admin`, never by the running app.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-now
