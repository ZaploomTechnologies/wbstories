# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# ---- Backend ----
# Server-reachable base URL of the main wbstories app — every /api/* and
# /uploads/* request is proxied there (see next.config.ts). No trailing slash.
API_ORIGIN=http://localhost:3000

# ---- Auth ----
# Must be the exact same value as JWT_SECRET in the main app's .env.local.
# Used only so this app's own middleware can verify the session cookie
# locally to redirect unauthenticated users to /login — it never mints
# tokens, only the main app's /api/auth/login does that.
JWT_SECRET=replace-with-a-long-random-secret
